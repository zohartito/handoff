{
  "name": "@zohartito/handoff",
  "version": "0.2.1",
  "description": "Portable agent state across AI coding tools — hand off mid-task between Claude Code, Cursor, Codex, and Gemini without re-explaining.",
  "type": "module",
  "bin": {
    "handoff": "./bin/handoff.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/tests/**/*.test.js\"",
    "test:watch": "node --test --watch \"dist-test/tests/**/*.test.js\"",
    "prepublishOnly": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "handoff",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "gemini",
    "cli",
    "context",
    "session",
    "llm"
  ],
  "license": "MIT",
  "author": "Zohar Tito",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zohartito/handoff.git"
  },
  "bugs": {
    "url": "https://github.com/zohartito/handoff/issues"
  },
  "homepage": "https://github.com/zohartito/handoff#readme",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
